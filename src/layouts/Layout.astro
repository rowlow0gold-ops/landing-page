      radial-gradient(1px 1px at 9% 72%, rgba(255,255,255,0.5), transparent),
      radial-gradient(1px 1px at 26% 88%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1px 1px at 42% 65%, rgba(255,255,255,0.5), transparent),
