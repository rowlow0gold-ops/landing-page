      radial-gradient(1px 1px at 1% 50%, rgba(255,255,255,0.4), transparent);
    z-index: 0;
  }

  /* Twinkling bright stars */
  .stars-twinkle {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 1;
    transition: opacity 1s ease;
    background-image:
      radial-gradient(3px 3px at 15% 10%, #fff, transparent),
      radial-gradient(2.5px 2.5px at 40% 25%, #fff, transparent),
      radial-gradient(3px 3px at 62% 8%, #fff, transparent),
      radial-gradient(2.5px 2.5px at 80% 42%, #fff, transparent),
      radial-gradient(3px 3px at 25% 65%, #fff, transparent),
      radial-gradient(2.5px 2.5px at 55% 55%, #fff, transparent),
      radial-gradient(3px 3px at 90% 72%, #fff, transparent),
      radial-gradient(2.5px 2.5px at 8% 85%, #fff, transparent),
      radial-gradient(3px 3px at 45% 90%, #fff, transparent),
      radial-gradient(2.5px 2.5px at 72% 78%, #fff, transparent),
      radial-gradient(3px 3px at 35% 48%, #fff, transparent),
      radial-gradient(2.5px 2.5px at 95% 18%, #fff, transparent);
    animation: twinkle 3s ease-in-out infinite alternate;
    z-index: 0;
  }

  @keyframes twinkle {
    0% { opacity: 0.2; }
    50% { opacity: 0.8; }
    100% { opacity: 1; }
  }

  /* In light mode, hide stars */
  html.light .stars-dense,
  html.light .stars-twinkle {
    opacity: 0 !important;
    animation: none;
  }

  /* Light mode clouds (subtle) */
  html.light body::before {
    content: "";
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    background-image:
      radial-gradient(ellipse 300px 80px at 15% 20%, rgba(255,255,255,0.6), transparent),
      radial-gradient(ellipse 250px 60px at 70% 15%, rgba(255,255,255,0.5), transparent),
      radial-gradient(ellipse 200px 50px at 85% 35%, rgba(255,255,255,0.4), transparent),
      radial-gradient(ellipse 350px 70px at 40% 70%, rgba(255,255,255,0.3), transparent);
  }

  /* Top controls (lang switcher + theme toggle) */
  .top-controls {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .lang-switcher {
    display: flex;
    gap: 0.2rem;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 0.25rem;
    backdrop-filter: blur(12px);
    transition: background 1s ease, border-color 1s ease;
  }

  .lang-btn {
    padding: 0.3rem 0.5rem;
    font-size: 0.7rem;
    font-weight: 600;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .lang-btn:hover {
    color: var(--text);
  }

  .lang-btn.active {
    background: var(--card-hover-bg);
    color: var(--text);
  }

  /* Theme toggle button */
  .theme-toggle {
    width: 44px;
    height: 44px;
    border: 1px solid var(--card-border);
    border-radius: 12px;
    background: var(--card-bg);
    backdrop-filter: blur(12px);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s ease;
    font-size: 1.2rem;
    padding: 0;
  }

  .theme-toggle:hover {
    background: var(--card-hover-bg);
    border-color: var(--card-hover-border);
    transform: scale(1.05);
  }

  /* Show/hide icons based on theme */
  .dark-icon {
    display: inline;
  }
  .light-icon {
    display: none;
  }
  html.light .dark-icon {
    display: none;
  }
  html.light .light-icon {
    display: inline;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  /* Smooth color transitions for all themed elements */
  body, .content-wrapper, .theme-toggle {
    transition: color 1s ease;
  }

  .content-wrapper {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    min-height: 100vh;
    padding-top: 3rem;
    padding-bottom: 2rem;
  }
</style>
