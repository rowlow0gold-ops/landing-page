---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="minhojan, portfolio, web projects, IP checker, developer" />
    <link rel="canonical" href="https://minhojan-world.site" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://minhojan-world.site" />
    <meta property="og:locale" content="ko_KR" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>

    <!-- Theme init: runs before paint to prevent flash -->
    <script is:inline>
      (function() {
        const saved = localStorage.getItem('theme');
        if (saved === 'light' || (!saved && window.matchMedia('(prefers-color-scheme: light)').matches)) {
          document.documentElement.classList.add('light');
        }
      })();
    </script>
  </head>
  <body>
    <div class="stars-dense"></div>
    <div class="stars-twinkle"></div>

    <!-- Top controls -->
    <div class="top-controls">
      <div class="lang-switcher" id="langSwitcher">
        <button class="lang-btn" data-lang="en">EN</button>
        <button class="lang-btn" data-lang="zh">中</button>
        <button class="lang-btn" data-lang="ko">한</button>
        <button class="lang-btn" data-lang="ja">日</button>
        <button class="lang-btn" data-lang="ru">RU</button>
      </div>
      <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
        <span class="toggle-icon dark-icon">☀️</span>
        <span class="toggle-icon light-icon">🌙</span>
      </button>
    </div>

    <div class="content-wrapper">
      <slot />
    </div>

    <script is:inline>
      document.getElementById('themeToggle').addEventListener('click', function() {
        document.documentElement.classList.toggle('light');
        const isLight = document.documentElement.classList.contains('light');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
      });

      // i18n
      var i18n = {
        ko: {
          subtitle: '웹 프로젝트 모음',
          project_0_name: '용산구청 클론', project_0_nameEn: 'Yongsan District Clone', project_0_desc: '용산구청 홈페이지 클론 프로젝트',
          project_1_name: '내 IP 확인', project_1_nameEn: 'My IP Checker', project_1_desc: '공인 IP 주소와 위치 정보를 빠르게 확인',
          project_2_name: '포트폴리오', project_2_nameEn: 'Landing Page', project_2_desc: '프로젝트 포털 랜딩 페이지',
          project_3_name: '계산기 모음', project_3_nameEn: 'Calculator Hub', project_3_desc: '나이, 환율, BMI 등 다양한 계산기 모음',
          project_4_name: '시스템 모니터', project_4_nameEn: 'System Monitor', project_4_desc: 'CPU, RAM, 네트워크, 디스크 실시간 모니터링 데스크톱 앱',
          coming: '준비중', footer: '\u00A9 2026 minhojan world. All rights reserved.',
        },
        en: {
          subtitle: 'Web Project Collection',
          project_0_name: 'Yongsan District Clone', project_0_nameEn: 'Yongsan District Clone', project_0_desc: 'Clone of Yongsan district government website',
          project_1_name: 'My IP Checker', project_1_nameEn: 'My IP Checker', project_1_desc: 'Quickly check your public IP and location',
          project_2_name: 'Portfolio', project_2_nameEn: 'Landing Page', project_2_desc: 'Project portal landing page',
          project_3_name: 'Calculator Hub', project_3_nameEn: 'Calculator Hub', project_3_desc: 'Age, currency, BMI and more calculators',
          project_4_name: 'System Monitor', project_4_nameEn: 'System Monitor', project_4_desc: 'Real-time CPU, RAM, network, disk monitoring desktop app',
          coming: 'Coming', footer: '\u00A9 2026 minhojan world. All rights reserved.',
        },
        ja: {
          subtitle: 'ウェブプロジェクト集',
          project_0_name: '龍山区庁クローン', project_0_nameEn: 'Yongsan District Clone', project_0_desc: '龍山区庁ホームページのクローンプロジェクト',
          project_1_name: 'IP確認', project_1_nameEn: 'My IP Checker', project_1_desc: 'グローバルIPとロケーション情報を素早く確認',
          project_2_name: 'ポートフォリオ', project_2_nameEn: 'Landing Page', project_2_desc: 'プロジェクトポータルランディングページ',
          project_3_name: '計算機コレクション', project_3_nameEn: 'Calculator Hub', project_3_desc: '年齢、為替、BMIなど様々な計算機',
          project_4_name: 'システムモニター', project_4_nameEn: 'System Monitor', project_4_desc: 'CPU、RAM、ネットワーク、ディスクのリアルタイム監視デスクトップアプリ',
          coming: '準備中', footer: '\u00A9 2026 minhojan world. All rights reserved.',
        },
        zh: {
          subtitle: '网页项目合集',
          project_0_name: '龙山区厅克隆', project_0_nameEn: 'Yongsan District Clone', project_0_desc: '龙山区政府网站克隆项目',
          project_1_name: '查看我的IP', project_1_nameEn: 'My IP Checker', project_1_desc: '快速查看公网IP地址和位置信息',
          project_2_name: '作品集', project_2_nameEn: 'Landing Page', project_2_desc: '项目门户着陆页',
          project_3_name: '计算器合集', project_3_nameEn: 'Calculator Hub', project_3_desc: '年龄、汇率、BMI等多种计算器',
          project_4_name: '系统监控器', project_4_nameEn: 'System Monitor', project_4_desc: 'CPU、RAM、网络、磁盘实时监控桌面应用',
          coming: '准备中', footer: '\u00A9 2026 minhojan world. All rights reserved.',
        },
        ru: {
          subtitle: 'Коллекция веб-проектов',
          project_0_name: 'Клон сайта Ёнсан', project_0_nameEn: 'Yongsan District Clone', project_0_desc: 'Клон сайта администрации района Ёнсан',
          project_1_name: 'Мой IP', project_1_nameEn: 'My IP Checker', project_1_desc: 'Быстрая проверка публичного IP и местоположения',
          project_2_name: 'Портфолио', project_2_nameEn: 'Landing Page', project_2_desc: 'Портал проектов',
          project_3_name: 'Калькуляторы', project_3_nameEn: 'Calculator Hub', project_3_desc: 'Возраст, валюта, ИМТ и другие калькуляторы',
          project_4_name: 'Системный монитор', project_4_nameEn: 'System Monitor', project_4_desc: 'Мониторинг CPU, RAM, сети и диска в реальном времени',
          coming: 'Скоро', footer: '\u00A9 2026 minhojan world. All rights reserved.',
        },
      };

      function detectLang() {
        var saved = localStorage.getItem('lang');
        if (saved && i18n[saved]) return saved;
        var nav = (navigator.language || '').toLowerCase();
        if (nav.startsWith('ko')) return 'ko';
        if (nav.startsWith('ja')) return 'ja';
        if (nav.startsWith('zh')) return 'zh';
        if (nav.startsWith('ru')) return 'ru';
        return 'en';
      }

      function setLang(lang) {
        localStorage.setItem('lang', lang);
        var texts = i18n[lang] || i18n['ko'];
        document.querySelectorAll('[data-i18n]').forEach(function(el) {
          var key = el.getAttribute('data-i18n');
          if (texts[key]) el.textContent = texts[key];
        });
        document.querySelectorAll('.lang-btn').forEach(function(btn) {
          btn.classList.toggle('active', btn.getAttribute('data-lang') === lang);
        });
      }

      // Init language
      setLang(detectLang());

      // Lang switcher clicks
      document.getElementById('langSwitcher').addEventListener('click', function(e) {
        var btn = e.target.closest('.lang-btn');
        if (btn) setLang(btn.getAttribute('data-lang'));
      });

      // Log visitor to Supabase
      (function() {
        var SUPABASE_URL = 'https://xxzveiasemaspdonppgf.supabase.co';
        var SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inh4enZlaWFzZW1hc3Bkb25wcGdmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU1MTcyMTYsImV4cCI6MjA5MTA5MzIxNn0.lKo4N6xPM9XHcMIPMPr5KgL81VKglMUgYMmEpsFXCfc';
        if (window.location.hostname !== 'minhojan-world.site') return;
        if (sessionStorage.getItem('visited')) return;
        sessionStorage.setItem('visited', '1');
        fetch('https://ipapi.co/json/')
          .then(function(r) { return r.json(); })
          .then(function(geo) {
            fetch(SUPABASE_URL + '/rest/v1/visits', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'apikey': SUPABASE_KEY,
                'Authorization': 'Bearer ' + SUPABASE_KEY,
              },
              body: JSON.stringify({
                ip: geo.ip,
                country: geo.country_name,
                region: geo.region,
                city: geo.city,
                isp: geo.org || '',
                page: 'landing',
              }),
            });
          })
          .catch(function() {});
      })();
    </script>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    overflow-y: auto;
    height: auto;
  }

  /* ===== Dark mode (default) ===== */
  :root {
    --text: #fff;
    --text-sub: rgba(255, 255, 255, 0.5);
    --text-muted: rgba(255, 255, 255, 0.35);
    --text-faint: rgba(255, 255, 255, 0.25);
    --card-bg: rgba(255, 255, 255, 0.06);
    --card-border: rgba(255, 255, 255, 0.1);
    --card-hover-bg: rgba(255, 255, 255, 0.1);
    --card-hover-border: rgba(255, 255, 255, 0.2);
    --tag-bg: rgba(255, 255, 255, 0.06);
    --tag-text: rgba(255, 255, 255, 0.4);
    --tag-border: rgba(255, 255, 255, 0.06);
    --divider: rgba(255, 255, 255, 0.06);
  }

  /* ===== Light mode ===== */
  html.light {
    --text: #1a2233;
    --text-sub: rgba(26, 34, 51, 0.6);
    --text-muted: rgba(26, 34, 51, 0.4);
    --text-faint: rgba(26, 34, 51, 0.3);
    --card-bg: rgba(255, 255, 255, 0.7);
    --card-border: rgba(255, 255, 255, 0.8);
    --card-hover-bg: rgba(255, 255, 255, 0.9);
    --card-hover-border: rgba(255, 255, 255, 1);
    --tag-bg: rgba(0, 0, 0, 0.05);
    --tag-text: rgba(26, 34, 51, 0.55);
    --tag-border: rgba(0, 0, 0, 0.08);
    --divider: rgba(0, 0, 0, 0.06);
  }

  body {
    min-height: 100vh;
    background: linear-gradient(180deg, #0a0a1a 0%, #0d1117 40%, #111827 100%);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    color: var(--text);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem 1rem;
    position: relative;
    overflow-x: hidden;
    overflow-y: visible;
  }

  /* Light sky overlay — fades in smoothly */
  body::after {
    content: "";
    position: fixed;
    inset: 0;
    background: linear-gradient(180deg, #e0f0ff 0%, #c8e6ff 40%, #a8d4ff 100%);
    opacity: 0;
    transition: opacity 1s ease;
    z-index: -1;
    pointer-events: none;
  }

  html.light body::after {
    opacity: 1;
  }

  /* Stars - dense layer */
  .stars-dense {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 1;
    transition: opacity 1s ease;
    background-image:
      radial-gradient(2px 2px at 10% 8%, #fff, transparent),
      radial-gradient(2.5px 2.5px at 25% 18%, #fff, transparent),
