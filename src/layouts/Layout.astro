      radial-gradient(1.5px 1.5px at 85% 52%, rgba(255,255,255,0.7), transparent),
      radial-gradient(1.5px 1.5px at 28% 62%, rgba(255,255,255,0.8), transparent),
      radial-gradient(1.5px 1.5px at 45% 70%, rgba(255,255,255,0.9), transparent),
      radial-gradient(1.5px 1.5px at 62% 82%, rgba(255,255,255,0.7), transparent),
      radial-gradient(1.5px 1.5px at 80% 72%, rgba(255,255,255,0.8), transparent),
      radial-gradient(1.5px 1.5px at 93% 88%, rgba(255,255,255,0.9), transparent),
      radial-gradient(1.5px 1.5px at 15% 78%, rgba(255,255,255,0.7), transparent),
      radial-gradient(1.5px 1.5px at 52% 85%, rgba(255,255,255,0.8), transparent),
