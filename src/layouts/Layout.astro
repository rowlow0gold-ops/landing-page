      radial-gradient(1px 1px at 36% 14%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1px 1px at 44% 26%, rgba(255,255,255,0.5), transparent),
      radial-gradient(1px 1px at 52% 33%, rgba(255,255,255,0.4), transparent),
