      radial-gradient(1px 1px at 76% 85%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1px 1px at 90% 95%, rgba(255,255,255,0.5), transparent),
      radial-gradient(1px 1px at 30% 95%, rgba(255,255,255,0.4), transparent),
