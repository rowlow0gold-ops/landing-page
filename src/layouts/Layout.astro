      radial-gradient(2px 2px at 78% 75%, #fff, transparent),
      radial-gradient(2px 2px at 95% 80%, #fff, transparent),
      radial-gradient(2px 2px at 12% 88%, #fff, transparent),
      radial-gradient(2.5px 2.5px at 35% 85%, #fff, transparent),
      radial-gradient(2px 2px at 55% 92%, #fff, transparent),
      radial-gradient(2px 2px at 88% 90%, #fff, transparent),
      radial-gradient(2.5px 2.5px at 3% 95%, #fff, transparent),
      radial-gradient(2px 2px at 65% 97%, #fff, transparent),
