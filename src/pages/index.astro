---
import Layout from "../layouts/Layout.astro";

const projects = [
  {
    name: "용산구청 클론",
    nameEn: "Yongsan District Clone",
    description: "용산구청 홈페이지 클론 프로젝트",
    url: "https://yongsan.minhojan-world.site",
    github: "https://github.com/rowlow0gold-ops/yongsan-site-exercise",
    icon: "🏛️",
    color: "#f093fb",
    status: "live",
    stack: ["Spring Boot 4", "Vue 3", "Vuetify", "PostgreSQL", "Redis", "JWT", "OAuth2", "Docker", "Nginx", "Prometheus", "Grafana", "GitHub Actions", "AWS Lightsail", "Managed Database"],
  },
  {
    name: "내 IP 확인",
    nameEn: "My IP Checker",
    description: "공인 IP 주소와 위치 정보를 빠르게 확인",
    url: "https://whats-my-ip.minhojan-world.site",
    github: "https://github.com/rowlow0gold-ops/my-ip-checker",
    icon: "🌐",
    color: "#667eea",
    status: "live",
    stack: ["Next.js", "TypeScript", "Tailwind CSS", "MapLibre GL", "Vercel"],
  },
  {
    name: "포트폴리오",
    nameEn: "Landing Page",
    description: "프로젝트 포털 랜딩 페이지",
    url: "https://minhojan-world.site",
    github: "https://github.com/rowlow0gold-ops/landing-page",
    icon: "🚀",
    color: "#764ba2",
    status: "live",
    stack: ["Astro", "Vercel"],
  },
  {
    name: "계산기 모음",
    nameEn: "Calculator Hub",
    description: "나이, 환율, BMI 등 다양한 계산기 모음",
    url: "https://calc-hub.minhojan-world.site",
    github: "https://github.com/rowlow0gold-ops/calculator-hub",
    icon: "🧮",
    color: "#4facfe",
    status: "live",
    stack: ["Nuxt 3", "TypeScript", "Vercel"],
  },
  {
    name: "시스템 모니터",
    nameEn: "System Monitor",
    description: "CPU, RAM, 네트워크, 디스크 실시간 모니터링 데스크톱 앱",
    url: "https://github.com/rowlow0gold-ops/system-monitor",
    icon: "📊",
    color: "#00bfff",
    status: "live",
    stack: ["Avalonia UI", "C#", ".NET 9", "LiveCharts", "SkiaSharp"],
  },
];
---

<Layout
  title="minhojan world"
  description="minhojan의 프로젝트 포털. IP 확인, 용산 프로젝트 등 다양한 서비스를 만나보세요."
>
  <div class="container">
    <!-- Logo & Title -->
    <header class="hero">
      <div class="logo">M</div>
      <h1>minhojan<span class="accent">.world</span></h1>
      <p class="subtitle" data-i18n="subtitle">웹 프로젝트 모음</p>
    </header>

    <!-- Project Cards -->
    <div class="projects">
      {projects.map((project, i) => (
        <div class:list={["card-wrapper", { disabled: project.status === "coming" }]} style={`--accent: ${project.color}`}>
          <a
            href={project.url}
            class="card"
            target={project.status === "live" ? "_blank" : undefined}
            rel="noopener noreferrer"
          >
            <div class="card-top">
              <div class="card-icon">{project.icon}</div>
              <div class="card-content">
                <h2 data-i18n={`project_${i}_name`}>{project.name}</h2>
                <span class="card-en" data-i18n={`project_${i}_nameEn`}>{project.nameEn}</span>
                <p data-i18n={`project_${i}_desc`}>{project.description}</p>
              </div>
              {project.status === "coming" ? (
                <span class="badge coming" data-i18n="coming">준비중</span>
              ) : (
                <span class="badge live">LIVE</span>
              )}
              <div class="card-arrow">→</div>
            </div>
            <div class="stack-tags">
              {project.stack.map((tech) => (
                <span class="stack-tag">{tech}</span>
              ))}
            </div>
          </a>
          {project.github && (
            <a href={project.github} class="github-link" target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
              <span>GitHub</span>
              <span class="github-arrow">→</span>
            </a>
          )}
        </div>
      ))}
    </div>

    <!-- Footer -->
    <footer>
      <p data-i18n="footer">&copy; 2026 minhojan world. All rights reserved.</p>
    </footer>
  </div>
</Layout>

<style>
  .container {
    max-width: 600px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  /* Hero */
  .hero {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .logo {
    width: 72px;
    height: 72px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 800;
    color: #fff !important;
    -webkit-text-fill-color: #fff !important;
    margin-bottom: 0.5rem;
    box-shadow: 0 8px 32px rgba(102, 126, 234, 0.4);
  }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .accent {
    background: linear-gradient(135deg, #667eea, #f093fb);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: var(--text-sub);
    font-size: 0.95rem;
    transition: color 1s ease;
  }

  /* Project Cards */
  .projects {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card-wrapper {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 16px;
    transition: all 0.25s ease, background 1s ease, border-color 1s ease;
    position: relative;
    overflow: hidden;
  }

  .card-wrapper::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .card-wrapper:hover {
    background: var(--card-hover-bg);
    border-color: var(--card-hover-border);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  .card-wrapper:hover::before {
    opacity: 1;
  }

  .card-wrapper.disabled {
    opacity: 0.5;
  }

  .card-wrapper.disabled .card {
    pointer-events: none;
  }

  .card {
    display: block;
    padding: 1.25rem 1.5rem;
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .card-icon {
    font-size: 2rem;
    flex-shrink: 0;
  }

  .card-content {
    flex: 1;
    min-width: 0;
  }

  .card-content h2 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 0.15rem;
  }

  .card-en {
    font-size: 0.75rem;
    color: var(--text-muted);
    display: block;
    margin-bottom: 0.35rem;
    transition: color 1s ease;
  }

  .card-content p {
    font-size: 0.85rem;
    color: var(--text-sub);
    line-height: 1.4;
    transition: color 1s ease;
  }

  .badge {
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    flex-shrink: 0;
  }

  .badge.live {
    background: rgba(52, 211, 153, 0.2);
    color: #34d399;
    border: 1px solid rgba(52, 211, 153, 0.3);
  }

  .badge.coming {
    background: rgba(251, 191, 36, 0.15);
    color: #fbbf24;
    border: 1px solid rgba(251, 191, 36, 0.25);
  }

  .card-arrow {
    font-size: 1.2rem;
    color: var(--text-muted);
    transition: transform 0.25s ease, color 0.25s ease;
    flex-shrink: 0;
  }

  .card-wrapper:hover .card-arrow {
    transform: translateX(4px);
    color: var(--text-sub);
  }

  /* Tech Stack tags (inside card link) */
  .stack-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    padding-top: 0.6rem;
  }

  .stack-tag {
    font-size: 0.6rem;
    font-weight: 500;
    padding: 0.15rem 0.5rem;
    border-radius: 5px;
    background: var(--tag-bg);
    color: var(--tag-text);
    border: 1px solid var(--tag-border);
    transition: background 1s ease, color 1s ease, border-color 1s ease;
  }

  /* GitHub link */
  .github-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1.5rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    transition: color 0.25s ease;
  }

  .github-link:hover {
    color: var(--text-sub);
  }

  .github-arrow {
    margin-left: auto;
    font-size: 1rem;
    transition: transform 0.25s ease;
  }

  .github-link:hover .github-arrow {
    transform: translateX(4px);
  }

  /* Footer */
  footer {
    margin-top: 1rem;
    color: var(--text-faint);
    font-size: 0.8rem;
  }

  /* Mobile */
  @media (max-width: 480px) {
    h1 {
      font-size: 1.6rem;
    }

    .card {
      padding: 1rem 1.25rem;
    }

    .card-icon {
      font-size: 1.6rem;
    }
  }
</style>
